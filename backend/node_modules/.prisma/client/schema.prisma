generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String?  @unique
  studentId     String?  @unique @map("student_id")
  fullName      String   @map("full_name")
  role          String
  passwordHash  String   @map("password_hash")
  expoPushToken String?  @map("expo_push_token")
  createdAt     DateTime @default(now()) @map("created_at")

  modulesLectured   Module[]         @relation("LecturerModules")
  enrolments        Enrolment[]
  proposals         EditProposal[]   @relation("ProposedBy")
  reviewedProposals EditProposal[]   @relation("ReviewedBy")
  noteVersions      NoteVersion[]
  annotations       NoteAnnotation[]
  comments          Comment[]
  images            NoteImage[]
  upvotes           ProposalUpvote[]
  exportedPdfs      ExportedPdf[]

  @@map("users")
}

model Module {
  id         String   @id @default(uuid())
  code       String
  name       String
  lecturerId String   @map("lecturer_id")
  enrollCode String   @unique @map("enrol_code")
  createdAt  DateTime @default(now()) @map("created_at")

  lecturer     User          @relation("LecturerModules", fields: [lecturerId], references: [id])
  enrolments   Enrolment[]
  notes        LectureNote[]
  exportedPdfs ExportedPdf[]

  @@map("modules")
}

model Enrolment {
  moduleId   String   @map("module_id")
  studentId  String   @map("student_id")
  enrolledAt DateTime @default(now()) @map("enrolled_at")

  module  Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([moduleId, studentId])
  @@map("enrolments")
}

model LectureNote {
  id               String   @id @default(uuid())
  moduleId         String   @map("module_id")
  lectureDate      DateTime @map("lecture_date")
  title            String
  baseFileUrl      String?  @map("base_file_url")
  baseFileType     String?  @map("base_file_type")
  currentVersionId String?  @map("current_version_id")
  isLocked         Boolean  @default(false) @map("is_locked")
  createdAt        DateTime @default(now()) @map("created_at")

  module       Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  versions     NoteVersion[]
  proposals    EditProposal[]
  annotations  NoteAnnotation[]
  comments     Comment[]
  images       NoteImage[]
  exportedPdfs ExportedPdf[]

  @@map("lecture_notes")
}

model NoteVersion {
  id            String   @id @default(uuid())
  noteId        String   @map("note_id")
  content       String
  versionNumber Int      @map("version_number")
  savedBy       String   @map("saved_by")
  savedAt       DateTime @default(now()) @map("saved_at")
  isPinned      Boolean  @default(false) @map("is_pinned")

  note        LectureNote      @relation(fields: [noteId], references: [id], onDelete: Cascade)
  savedByUser User             @relation(fields: [savedBy], references: [id])
  proposals   EditProposal[]
  annotations NoteAnnotation[]

  @@map("note_versions")
}

model EditProposal {
  id                     String    @id @default(uuid())
  noteId                 String    @map("note_id")
  proposedBy             String    @map("proposed_by")
  baseVersionId          String    @map("base_version_id")
  proposedContent        String    @map("proposed_content")
  summary                String
  upvoteCount            Int       @default(0) @map("upvote_count")
  status                 String    @default("pending")
  reviewedBy             String?   @map("reviewed_by")
  reviewedAt             DateTime? @map("reviewed_at")
  rejectionReason        String?   @map("rejection_reason")
  isInline               Boolean   @default(false) @map("is_inline")
  originalText           String?   @map("original_text")
  suggestedText          String?   @map("suggested_text")
  highlightStartOffset   Int?      @map("highlight_start_offset")
  highlightEndOffset     Int?      @map("highlight_end_offset")
  highlightContextBefore String?   @map("highlight_context_before")
  highlightContextAfter  String?   @map("highlight_context_after")
  createdAt              DateTime  @default(now()) @map("created_at")

  note        LectureNote      @relation(fields: [noteId], references: [id], onDelete: Cascade)
  proposer    User             @relation("ProposedBy", fields: [proposedBy], references: [id])
  reviewer    User?            @relation("ReviewedBy", fields: [reviewedBy], references: [id])
  baseVersion NoteVersion      @relation(fields: [baseVersionId], references: [id])
  upvotes     ProposalUpvote[]
  images      NoteImage[]

  @@map("edit_proposals")
}

model ProposalUpvote {
  proposalId String   @map("proposal_id")
  studentId  String   @map("student_id")
  createdAt  DateTime @default(now()) @map("created_at")

  proposal EditProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  student  User         @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([proposalId, studentId])
  @@map("proposal_upvotes")
}

model NoteAnnotation {
  id             String   @id @default(uuid())
  noteId         String   @map("note_id")
  versionId      String   @map("version_id")
  lecturerId     String   @map("lecturer_id")
  targetLine     Int      @map("target_line")
  annotationText String   @map("annotation_text")
  createdAt      DateTime @default(now()) @map("created_at")

  note     LectureNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
  version  NoteVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  lecturer User        @relation(fields: [lecturerId], references: [id])

  @@map("note_annotations")
}

model Comment {
  id              String   @id @default(uuid())
  noteId          String   @map("note_id")
  authorId        String   @map("author_id")
  parentCommentId String?  @map("parent_comment_id")
  content         String
  createdAt       DateTime @default(now()) @map("created_at")

  note    LectureNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
  author  User        @relation(fields: [authorId], references: [id])
  parent  Comment?    @relation("Replies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies Comment[]   @relation("Replies")

  @@map("comments")
}

model NoteImage {
  id                 String   @id @default(uuid())
  proposalId         String?  @map("proposal_id")
  noteId             String   @map("note_id")
  cloudinaryPublicId String   @map("cloudinary_public_id")
  publicUrl          String   @map("public_url")
  caption            String?
  uploadedBy         String   @map("uploaded_by")
  uploadedAt         DateTime @default(now()) @map("uploaded_at")
  isOrphaned         Boolean  @default(false) @map("is_orphaned")

  proposal EditProposal? @relation(fields: [proposalId], references: [id])
  note     LectureNote   @relation(fields: [noteId], references: [id], onDelete: Cascade)
  uploader User          @relation(fields: [uploadedBy], references: [id])

  @@map("note_images")
}

model ExportedPdf {
  id                 String   @id @default(uuid())
  noteId             String?  @map("note_id")
  moduleId           String   @map("module_id")
  cloudinaryPublicId String   @map("cloudinary_public_id")
  publicUrl          String   @map("public_url")
  exportedBy         String   @map("exported_by")
  isCompilation      Boolean  @default(false) @map("is_compilation")
  createdAt          DateTime @default(now()) @map("created_at")

  note     LectureNote? @relation(fields: [noteId], references: [id], onDelete: Cascade)
  module   Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  exporter User         @relation(fields: [exportedBy], references: [id])

  @@map("exported_pdfs")
}
